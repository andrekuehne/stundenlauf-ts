{
  "name": "stundenlauf-ts",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "ci:local": "pnpm install --frozen-lockfile && pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run build",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "inspect:excel-fixtures": "vite-node scripts/dump-local-excel-fixtures.ts"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.14.1",
    "workbox-window": "^7.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "globals": "^16",
    "jiti": "^2.6.1",
    "jsdom": "^26",
    "prettier": "^3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.8",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm run ci:local"
  }
}
